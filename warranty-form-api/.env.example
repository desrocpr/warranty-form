# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# HubSpot
HUBSPOT_PORTAL_ID=2719512
HUBSPOT_FORM_ID=eeafd136-fe2c-4a6a-852b-499e913cce16

# HubSpot Tickets (Warranty)
# Private app token with scopes: tickets, crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
HUBSPOT_TICKET_PIPELINE_ID=902566925
HUBSPOT_TICKET_STAGE_NEW=1365055596
HUBSPOT_TICKET_STAGE_TRIAGE=1365055597
HUBSPOT_TICKET_STAGE_WORK=1365055599
HUBSPOT_TICKET_STAGE_RESOLVED=1364899667

# EasyTerritory API (Moss)
EASYTERRITORY_BASE_URL=https://apps.easyterritory.com
EASYTERRITORY_GUID=your_easyterritory_guid
EASYTERRITORY_INSTANCE_TYPE=APP
EASYTERRITORY_USERNAME=your_username
EASYTERRITORY_PASSWORD=your_password
EASYTERRITORY_PROJECT_ID=your_project_id

# External API Key (bypasses Turnstile for server-to-server calls)
CONTACT_API_KEY=your_contact_api_key

# Cron Security (generate with: openssl rand -hex 32)
CRON_SECRET=your_cron_secret

# Fallback Calendar URL
DEFAULT_CALENDAR_URL=http://www.mossbuildinganddesign.com/default-meetings

# Out-of-Service URL (when neither Moss nor Renolution has territory)
OUT_OF_SERVICE_URL=https://www.mossbuildinganddesign.com/out-of-service-area
